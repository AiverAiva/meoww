---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Features from '../../components/Features.astro';
import Footer from '../../components/Footer.astro';

const title = 'Meoww - Your Discord Companion';
const description = 'A cute and powerful Discord bot with link previews, music playback, and fun interactions.';
---

<Layout title={title} description={description} locale="en">
  <Header />
  <main>
    <Hero />
    <Features />
  </main>
  <Footer />
</Layout>